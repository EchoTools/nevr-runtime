{
    "version": 4,
    "configurePresets": [
        {
            "name": "msvc-flags",
            "hidden": true,
            "cacheVariables": {
                "CMAKE_CXX_FLAGS": "/diagnostics:color"
            }
        },
        {
            "name": "base",
            "hidden": true,
            "inherits": "msvc-flags",
            "generator": "Ninja",
            "binaryDir": "${sourceDir}/build/${presetName}",
            "cacheVariables": {
                "CMAKE_TOOLCHAIN_FILE": {
                    "type": "FILEPATH",
                    "value": "$env{VCPKG_ROOT}/scripts/buildsystems/vcpkg.cmake"
                },
                "VCPKG_VERBOSE": "OFF",
                "CMAKE_COLOR_DIAGNOSTICS": "ON"
            }
        },
        {
            "name": "debug",
            "displayName": "Debug",
            "inherits": "base",
            "cacheVariables": {
                "CMAKE_BUILD_TYPE": "Debug"
            }
        },
        {
            "name": "release",
            "displayName": "Release",
            "inherits": "base",
            "cacheVariables": {
                "CMAKE_BUILD_TYPE": "Release"
            }
        },
        {
            "name": "linux-wine-base",
            "hidden": true,
            "generator": "Ninja",
            "binaryDir": "${sourceDir}/build/linux-wine-${presetName}",
            "toolchainFile": "${sourceDir}/cmake/toolchain-msvc-wine.cmake",
            "cacheVariables": {
                "CMAKE_COLOR_DIAGNOSTICS": "ON",
                "VCPKG_TARGET_TRIPLET": "x64-windows",
                "CMAKE_PREFIX_PATH": "${sourceDir}/vcpkg_installed/x64-windows"
            }
        },
        {
            "name": "linux-wine-debug",
            "displayName": "Linux Wine Debug",
            "inherits": "linux-wine-base",
            "cacheVariables": {
                "CMAKE_BUILD_TYPE": "Debug"
            }
        },
        {
            "name": "linux-wine-release",
            "displayName": "Linux Wine Release",
            "inherits": "linux-wine-base",
            "cacheVariables": {
                "CMAKE_BUILD_TYPE": "Release"
            }
        }
    ],
    "buildPresets": [
        {
            "name": "debug",
            "displayName": "Build (Debug)",
            "configurePreset": "debug"
        },
        {
            "name": "release",
            "displayName": "Build (Release)",
            "configurePreset": "release"
        },
        {
            "name": "linux-wine-debug",
            "displayName": "Build Linux Wine (Debug)",
            "configurePreset": "linux-wine-debug"
        },
        {
            "name": "linux-wine-release",
            "displayName": "Build Linux Wine (Release)",
            "configurePreset": "linux-wine-release"
        }
    ]
}