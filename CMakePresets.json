{
    "version": 4,
    "configurePresets": [
        {
            "name": "msvc-flags",
            "hidden": true,
            "cacheVariables": {
                "CMAKE_CXX_FLAGS": "/diagnostics:color"
            }
        },
        {
            "name": "base",
            "hidden": true,
            "inherits": "msvc-flags",
            "generator": "Ninja",
            "binaryDir": "${sourceDir}/build/${presetName}",
            "toolchainFile": "$env{HOME}/.vcpkg/scripts/buildsystems/vcpkg.cmake",
            "cacheVariables": {
                "CMAKE_COLOR_DIAGNOSTICS": "ON"
            }
        },
        {
            "name": "debug",
            "displayName": "Debug",
            "inherits": "base",
            "cacheVariables": {
                "CMAKE_BUILD_TYPE": "Debug"
            }
        },
        {
            "name": "release",
            "displayName": "Release",
            "inherits": "base",
            "cacheVariables": {
                "CMAKE_BUILD_TYPE": "Release"
            }
        },
        {
            "name": "linux-wine-base",
            "hidden": true,
            "generator": "Ninja",
            "binaryDir": "${sourceDir}/build/linux-wine-${presetName}",
            "toolchainFile": "${sourceDir}/cmake/toolchain-msvc-wine.cmake",
            "cacheVariables": {
                "CMAKE_COLOR_DIAGNOSTICS": "ON"
            }
        },
        {
            "name": "linux-wine-debug",
            "displayName": "Linux Wine Debug",
            "inherits": "linux-wine-base",
            "cacheVariables": {
                "CMAKE_BUILD_TYPE": "Debug"
            }
        },
        {
            "name": "linux-wine-release",
            "displayName": "Linux Wine Release",
            "inherits": "linux-wine-base",
            "cacheVariables": {
                "CMAKE_BUILD_TYPE": "Release"
            }
        },
        {
            "name": "mingw-base",
            "hidden": true,
            "generator": "Ninja",
            "binaryDir": "${sourceDir}/build/${presetName}",
            "toolchainFile": "$env{HOME}/.vcpkg/scripts/buildsystems/vcpkg.cmake",
            "cacheVariables": {
                "CMAKE_COLOR_DIAGNOSTICS": "ON",
                "VCPKG_TARGET_TRIPLET": "x64-mingw-static",
                "VCPKG_HOST_TRIPLET": "x64-linux",
                "VCPKG_CHAINLOAD_TOOLCHAIN_FILE": "${sourceDir}/cmake/toolchain-mingw64.cmake",
                "VCPKG_APPLOCAL_DEPS": "OFF"
            }
        },
        {
            "name": "mingw-debug",
            "displayName": "MinGW Debug",
            "inherits": "mingw-base",
            "cacheVariables": {
                "CMAKE_BUILD_TYPE": "Debug"
            }
        },
        {
            "name": "mingw-release",
            "displayName": "MinGW Release",
            "inherits": "mingw-base",
            "cacheVariables": {
                "CMAKE_BUILD_TYPE": "Release"
            }
        }
    ],
    "buildPresets": [
        {
            "name": "debug",
            "displayName": "Build (Debug)",
            "configurePreset": "debug"
        },
        {
            "name": "release",
            "displayName": "Build (Release)",
            "configurePreset": "release"
        },
        {
            "name": "linux-wine-debug",
            "displayName": "Build Linux Wine (Debug)",
            "configurePreset": "linux-wine-debug"
        },
        {
            "name": "linux-wine-release",
            "displayName": "Build Linux Wine (Release)",
            "configurePreset": "linux-wine-release"
        },
        {
            "name": "mingw-debug",
            "displayName": "Build MinGW (Debug)",
            "configurePreset": "mingw-debug"
        },
        {
            "name": "mingw-release",
            "displayName": "Build MinGW (Release)",
            "configurePreset": "mingw-release"
        }
    ]
}